│       └── main.yml             <-- [Stage 1, 2, & 3 Workflow Configuration]
├── demo_aws_ec2.yml             <-- [Ansible Dynamic Inventory Map]
├── deploy.yml                   <-- [Ansible Instructions Playbook]
└── helloworld.py                <-- [Your Python Application Script]
